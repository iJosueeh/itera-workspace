# ==========================================
# ITERA WORKSPACE - ENV TEMPLATE
# ==========================================

# ==========================================
# INFRASTRUCTURE - TRAEFIK
# ==========================================
TRAEFIK_DASHBOARD_PORT=8081
TRAEFIK_ENTRYPOINT_PORT=80

# ==========================================
# FRONTEND - ANGULAR
# ==========================================
ANGULAR_PORT=4200
ANGULAR_ENV=development

# URL pública consumida por Angular
API_GATEWAY_URL=http://localhost

# ==========================================
# BACKEND - SCALA (PLAY FRAMEWORK)
# ==========================================
SCALA_PORT=8080
SCALA_ENV=development

# ==========================================
# DATABASE - NEON POSTGRESQL
# ==========================================

# Base de datos Neon
DB_URL=jdbc:postgresql://YOUR_NEON_HOST/itera_scala_db?sslmode=require&channelBinding=require
PLAY_SECRET_KEY=itera-play-secret-key-2026-super-secure-min-32-chars

# Credenciales Neon
DB_USER=neondb_owner
DB_PASSWORD=YOUR_NEON_PASSWORD

# ==========================================
# BACKEND - PYTHON (FASTAPI)
# ==========================================
PYTHON_PORT=8000
PYTHON_ENV=development

# ==========================================
# DATABASE - MONGODB ATLAS
# ==========================================

# Ejemplo:
# mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Base de datos utilizada por IA
MONGODB_DATABASE=itera_ia

# ==========================================
# LOGIC - PROLOG
# ==========================================
PROLOG_PORT=9000

# ==========================================
# INTERNAL MICROSERVICES URLS
# ==========================================

# Comunicación interna Docker
IA_API_URL=http://backend-python:8000
LOGICA_API_URL=http://prolog:9000

# ==========================================
# SECURITY
# ==========================================

# Generar una cadena segura de al menos 32 caracteres
JWT_SECRET=generate_a_long_random_string_here

# Opcional Play Framework
PLAY_SECRET_KEY=generate_another_long_random_string_here