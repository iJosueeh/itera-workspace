# ==========================================
# Configuración de Itera Workspace - Ejemplo
# ==========================================
# Copiar este archivo a .env y ajustar valores

# ==========================================
# INFRASTRUCTURE - Traefik
# ==========================================
TRAEFIK_DASHBOARD_PORT=8081
TRAEFIK_ENTRYPOINT_PORT=80

# ==========================================
# DATABASE - PostgreSQL (Neon or Local)
# ==========================================
# For Neon, use the full connection string:
# DB_URL=jdbc:postgresql://host:port/dbname?user=itera_user&password=itera_pass&sslmode=require
DB_URL=jdbc:postgresql://your-neon-host/dbname?user=your-user&password=your-password&sslmode=require
POSTGRES_DB=itera_db
POSTGRES_USER=itera_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_PORT=5432

# ==========================================
# FRONTEND - Angular
# ==========================================
ANGULAR_PORT=4200
ANGULAR_ENV=development

# ==========================================
# BACKEND - Scala
# ==========================================
SCALA_PORT=8080
SCALA_ENV=development

# ==========================================
# BACKEND - Python
# ==========================================
PYTHON_PORT=8000
PYTHON_ENV=development

# ==========================================
# LOGIC - Prolog
# ==========================================
PROLOG_PORT=9000

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=generate_a_long_random_string_here
API_GATEWAY_URL=http://localhost/api/v1
