# ==========================================
# Configuración de Itera Workspace
# ==========================================
# Copiar este archivo a .env y ajustar valores

# ==========================================
# FRONTEND - Angular
# ==========================================
ANGULAR_PORT=4200
ANGULAR_ENV=development

# ==========================================
# BACKEND - Scala
# ==========================================
SCALA_PORT=8080
SCALA_ENV=development
SCALA_LOG_LEVEL=INFO
PYTHON_API_URL=http://backend-python:8000
PROLOG_URL=http://prolog:9000

# ==========================================
# BACKEND - Python
# ==========================================
PYTHON_PORT=8000
PYTHON_ENV=development
PYTHON_LOG_LEVEL=INFO
PROLOG_URL=http://prolog:9000

# ==========================================
# LOGIC - Prolog
# ==========================================
PROLOG_PORT=9000
PROLOG_TIMEOUT=30000
PROLOG_MAX_SOLUTIONS=1000

# ==========================================
# DOCKER
# ==========================================
COMPOSE_PROJECT_NAME=itera-platform
COMPOSE_FILE=docker-compose.yml

# ==========================================
# DATABASE (si aplica)
# ==========================================
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=itera_db
# DB_USER=itera_user
# DB_PASSWORD=your_secure_password

# ==========================================
# AUTENTICACIÓN
# ==========================================
# JWT_SECRET=your_jwt_secret_here
# API_KEY=your_api_key_here

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json
