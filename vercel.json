{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "angular",
  "buildCommand": "cd itera-angular && npm install && npx ng build --configuration production",
  "outputDirectory": "itera-angular/dist/itera/browser",
  "installCommand": "npm install -g @angular/cli && cd itera-angular && npm install",
  "rewrites": [
    {
      "source": "/api/core/:path*",
      "destination": "https://itera-backend-ytoy.onrender.com/api/core/:path*"
    },
    {
      "source": "/api/ia/:path*",
      "destination": "https://itera-backend-ytoy.onrender.com/api/ia/:path*"
    },
    {
      "source": "/api/logic/:path*",
      "destination": "https://itera-backend-ytoy.onrender.com/api/logic/:path*"
    },
    {
      "source": "/health",
      "destination": "https://itera-backend-ytoy.onrender.com/health"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS,PATCH" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-Requested-With" }
      ]
    }
  ],
  "env": {
    "API_GATEWAY_URL": "https://itera-backend-ytoy.onrender.com"
  }
}
